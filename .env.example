# GN Tracing Extension - Environment Configuration

# Google OAuth (required for Drive upload)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Player Configuration (optional)
# URL của standalone player deployment
# Nếu set, extension sẽ dùng làm default (user có thể override trong popup)
# Nếu để trống, extension dùng built-in player
PLAYER_HOST_URL=
