{
  "name": "gn-tracing",
  "version": "1.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "player:sync": "cd player-standalone && node scripts/sync-player.js",
    "player:dev": "cd player-standalone && npm run dev",
    "player:build": "cd player-standalone && npm run build",
    "player:preview": "cd player-standalone && npm run preview",
    "player:deploy": "cd player-standalone && npm run deploy",
    "player:deploy:cloudflare": "cd player-standalone && npm run deploy:cloudflare",
    "build:all": "npm run build && npm run player:sync && npm run player:build",
    "release:build": "npm run build",
    "release:artifact": "sh -c 'zip -r \"gn-tracing-extension-${GITHUB_REF_NAME:-local}.zip\" dist'",
    "release:ci": "npm run release:build && npm run release:artifact",
    "watch:all": "concurrently 'npm run watch' 'npm run player:dev'"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
